{
  "name": "taipei-1999-map",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:pages": "tsc --noEmit && vite build --base /taipei-1999-map/",
    "preview": "vite preview",
    "test": "vitest run",
    "convert:data": "tsx scripts/convertOpen1999.ts",
    "fetch:data": "tsx scripts/fetchOpen1999Resources.ts",
    "data:fetch:streetlight": "tsx scripts/fetchStreetlightRepairs.ts",
    "data:convert:streetlight": "tsx scripts/convertStreetlightRepairs.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.2",
    "leaflet": "^1.9.4",
    "papaparse": "^5.5.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.0.2",
    "@types/papaparse": "^5.3.16",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.0.16"
  }
}
